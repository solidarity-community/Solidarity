FROM mcr.microsoft.com/dotnet/sdk:7.0 AS build
WORKDIR /Solidarity
COPY *.csproj .
RUN dotnet restore
COPY . .
RUN dotnet test
RUN dotnet publish -c Release -o dist

FROM mcr.microsoft.com/dotnet/aspnet:7.0
WORKDIR /Solidarity
COPY --from=build /Solidarity/dist .
EXPOSE 80
EXPOSE 443
ENTRYPOINT ["dotnet", "Solidarity.dll"]